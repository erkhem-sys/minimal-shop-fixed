# --- Сервер ---
PORT=4000
NODE_ENV=development

# --- Database (PostgreSQL) ---
# Render/Railway зэрэг hosting ашиглах бол DATABASE_URL-ийг бөглөнө (доор тайлбарласан).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/minimal_shop
DATABASE_SSL=false

# Local PostgreSQL ашиглах бол (DATABASE_URL хоосон үед ашиглагдана)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=minimal_shop

# --- JWT ---
# Random, урт нууц түлхүүр ашиглана уу. Жишээ нь: openssl rand -base64 48
JWT_SECRET=change_this_to_a_long_random_secret_string

# --- CORS ---
# Frontend-ийн URL (production дээр Vercel-ийн домэйноор солино)
CORS_ORIGIN=http://localhost:5173

# --- Upload ---
# Local storage ашиглах үед хуулсан зурагны public URL угтвар
PUBLIC_BASE_URL=http://localhost:4000

# --- Seed script ---
SEED_ADMIN_EMAIL=admin@minimalshop.mn
SEED_ADMIN_PASSWORD=Admin12345!
